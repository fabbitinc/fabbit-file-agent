{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fabbit",
  "version": "0.1.0",
  "identifier": "com.moseoh.fabbit-file-agent",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fabbit",
        "width": 400,
        "height": 500,
        "visible": false,
        "decorations": true,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
"security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "languages": ["Korean", "English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
